x = c(20,4)
matrx = matrix(x, ncol = 2)
colnames(matrx) = c("ja", "nein")
rownames(matrx) = c("ja", "nein")
rownames(matrx) = c("activity",ja", "nein")
rownames(matrx) = c("activity","ja", "nein")
rownames(matrx) = c("activity", "ja", "nein")
print(matrx)
y = c(3,1)
matrx = matrix(x,y, nrow = 2)
print(matrx)
matrx = matrix(x, nrow = 2)
print(matrx)
matrx = matrix(x, nrow = 2, ncol = 2)
print(matrx)
matrx = matrix(bind(x,y),nrow=2,ncol=2)
matrx = matrix(rbind(x,y),nrow=2,ncol=2)
print(matrx)
matrx = matrix(cbind(x,y),nrow=2,ncol=2)
print(matrx)
colnames(matrx) = c("ja", "nein")
rownames(matrx) = c("ja", "nein")
print(matrx)
names(dimnames(matrx)) = c("activity","distance")
print(matrx)
tabledata = as.table(data)
row1 = c(20,4)
row2 = c(3,1)
data = matrix(cbind(x,y),nrow=2,ncol=2)
colnames(data) = c("ja", "nein")
rownames(data) = c("ja", "nein")
names(dimnames(data)) = c("activity", "distance")
tabledata = as.table(data)
print(tabledata)
