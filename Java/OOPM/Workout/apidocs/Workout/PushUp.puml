@startuml
    set namespaceSeparator none
    hide empty fields
    hide empty methods

    class "<size:14>PushUp\n<size:10>Workout" as Workout.PushUp [[PushUp.html]] {
        -repetitions: int
        +PushUp(Date, int)
        +getIntensity(): int
        +getEnergy(): int
    }

    class "<size:14>BasicWorkout\n<size:10>Workout" as Workout.BasicWorkout [[BasicWorkout.html]]

    Workout.BasicWorkout <|-- Workout.PushUp

    center footer UMLDoclet 2.0.12, PlantUML 1.2020.16
@enduml
